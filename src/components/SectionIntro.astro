---
const { eyebrow, title, lead, center = false } = Astro.props;
---

<div class:list={["section-intro", { "section-intro-center": center }]} data-reveal>
  {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
  <h2 class="section-title">{title}</h2>
  {lead && <p class="section-lead">{lead}</p>}
</div>
